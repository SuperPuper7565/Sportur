@using Sportur.Models
@model CatalogIndexViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/catalog.css" asp-append-version="true" />
}

<section class="catalog-header mb-4">
    <h2 class="mb-2">Каталог велосипедов</h2>
    <p class="catalog-subtitle mb-0">Подберите модель по характеристикам и бренду.</p>
</section>

<form method="get" class="catalog-filters mb-4">
    <div class="catalog-filters-grid">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Поиск по названию" />

        <select name="category" class="form-select" asp-for="Category" asp-items="Html.GetEnumSelectList<BicycleCategory>()">
            <option value="">Все категории</option>
        </select>

        <select name="wheelDiameter" class="form-select">
            <option value="">Все диаметры колес</option>
            @foreach (var value in Model.AvailableWheelDiameters)
            {
                <option value="@value" selected="@(value == Model.WheelDiameter ? "selected" : null)">@value</option>
            }
        </select>

        <select name="gearCount" class="form-select">
            <option value="">Любое кол-во скоростей</option>
            @foreach (var value in Model.AvailableGearCounts)
            {
                <option value="@value" selected="@(value == Model.GearCount ? "selected" : null)">@value</option>
            }
        </select>

        <select name="frameMaterial" class="form-select">
            <option value="">Любой материал рамы</option>
            @foreach (var value in Model.AvailableFrameMaterials)
            {
                <option value="@value" selected="@(value == Model.FrameMaterial ? "selected" : null)">@value</option>
            }
        </select>

        <select name="brakeType" class="form-select" asp-for="BrakeType" asp-items="Html.GetEnumSelectList<BrakeType>()">
            <option value="">Любой тип тормоза</option>
        </select>

        <select name="brand" class="form-select">
            <option value="">Все бренды</option>
            @foreach (var value in Model.AvailableBrands)
            {
                <option value="@value" selected="@(value == Model.Brand ? "selected" : null)">@value</option>
            }
        </select>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">Применить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Сбросить</a>
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="catalog-empty">
        <h5 class="mb-2">По вашему запросу ничего не найдено</h5>
        <p class="text-muted mb-0">Попробуйте убрать часть фильтров или изменить название модели.</p>
    </div>
}
else
{
    <div class="catalog-grid">
        @foreach (var item in Model.Items)
        {
            <a asp-action="Details"
               asp-route-id="@item.Id"
               class="catalog-link">

                <article class="card catalog-card">
                    @if (!string.IsNullOrEmpty(item.PreviewImageUrl))
                    {
                        <div class="catalog-image-wrap">
                            <img src="@item.PreviewImageUrl"
                                 class="catalog-image"
                                 alt="@item.ModelName" />
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="catalog-title mb-2">@item.Brand @item.ModelName</h5>

                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="catalog-chip">@item.Category</span>
                            <span class="catalog-colors text-muted">Цветов: @item.ColorsCount</span>
                        </div>

                        <p class="catalog-price mt-auto mb-0">@item.MinPrice ₽</p>
                    </div>
                </article>
            </a>
        }
    </div>
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Спортур</title>

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <span class="logo">Спортур</span>

        <nav>
            <a asp-controller="Catalog" asp-action="Index">Каталог товаров</a>
            <a asp-controller="Home" asp-action="About">О компании</a>
            <a asp-controller="Home" asp-action="Info">Где купить</a>
            <a asp-controller="Home" asp-action="Service">Гарантия и сервис</a>
            <a asp-controller="Home" asp-action="Contacts">Контакты</a>
        </nav>

        <div class="auth">
            @if (Context.Session.GetInt32("UserId") == null)
            {
                <a asp-controller="Account" asp-action="Login">Войти</a>
                <a asp-controller="Account" asp-action="Register">Регистрация</a>
            }
            else
            {
                <span>Привет, @Context.Session.GetString("UserName")</span>

                <a asp-controller="Order" asp-action="My">Мои заказы</a>

                @if (Context.Session.GetString("UserRole") == "Retail")
                {
                    var isWholesalePending = Context.Session.GetInt32("WholesalePending") == 1;

                    if (!isWholesalePending)
                    {
                        <form asp-controller="Account"
                              asp-action="RequestWholesaleAccess"
                              method="post"
                              style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="auth-action-button">
                                Подать заявку на оптовый статус
                            </button>
                        </form>
                    }
                    else
                    {
                        <span>Заявка на оптовый статус отправлена</span>
                    }
                }

                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a asp-area="Admin"
                       asp-controller="AdminOrder"
                       asp-action="Index">Админка</a>
                }

                <a asp-controller="Account" asp-action="Logout">Выйти</a>
            }
        </div>
    </header>

    @if (TempData["WholesalePendingMessage"] != null)
    {
        <div id="wholesale-popup"
             class="wholesale-popup-overlay"
             role="dialog"
             aria-modal="true"
             aria-labelledby="wholesale-popup-message">
            <div class="wholesale-popup-window">
                <button type="button"
                        class="wholesale-popup-close"
                        aria-label="Закрыть"
                        onclick="closeWholesalePopup()">
                    ×
                </button>
                <p id="wholesale-popup-message">
                    @TempData["WholesalePendingMessage"]
                </p>
            </div>
        </div>
    }

    <main class="container">
        @RenderBody()
    </main>

    <footer>
        <small>© Спортур, @DateTime.Now.Year</small>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/catalog.js" asp-append-version="true"></script>
    <script src="~/js/cart.js" asp-append-version="true"></script>

    <script>
        function closeWholesalePopup() {
            const popup = document.getElementById('wholesale-popup');
            if (popup) {
                popup.style.display = 'none';
            }
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>